From 854996b76ef63b4c652b8a72c467828f6a169b2f Mon Sep 17 00:00:00 2001
From: Phong Hoang <phong.hoang.wz@renesas.com>
Date: Mon, 26 Jul 2021 13:39:15 +0700
Subject: [PATCH 42/70] arm64: defconfig: Enable Para-CAN support

This patch enables Para Virtualized CAN drivers and related configurations.

Signed-off-by: Phong Hoang <phong.hoang.wz@renesas.com>
---
 arch/arm64/configs/defconfig | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/arch/arm64/configs/defconfig b/arch/arm64/configs/defconfig
index 6d7f28be63a1..adbd3160ef33 100644
--- a/arch/arm64/configs/defconfig
+++ b/arch/arm64/configs/defconfig
@@ -180,9 +180,11 @@ CONFIG_QRTR=m
 CONFIG_QRTR_SMD=m
 CONFIG_QRTR_TUN=m
 CONFIG_BPF_JIT=y
-CONFIG_CAN=m
+CONFIG_CAN=y
+CONFIG_CAN_DEV=y
 CONFIG_CAN_RCAR=m
 CONFIG_CAN_RCAR_CANFD=m
+CONFIG_CAN_RCAR_TAURUS=m
 CONFIG_CAN_FLEXCAN=m
 CONFIG_BT=m
 CONFIG_BT_HIDP=m
-- 
2.25.1

