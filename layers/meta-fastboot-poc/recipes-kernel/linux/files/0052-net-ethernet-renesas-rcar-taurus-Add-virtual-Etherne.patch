diff --git a/drivers/net/ethernet/renesas/rcar-taurus/Kconfig b/drivers/net/ethernet/renesas/rcar-taurus/Kconfig
new file mode 100644
index 000000000000..2b21bc0a2a5f
--- /dev/null
+++ b/drivers/net/ethernet/renesas/rcar-taurus/Kconfig
@@ -0,0 +1,9 @@
+config ETHER_RCAR_TAURUS
+	tristate "Renesas R-Car Taurus Ethernet driver"
+	depends on ARCH_RENESAS || ARM
+	help
+	  Say Y here if you want to use the Renesas Taurus Ethernet virtual
+	  driver for R-Car Gen3 SoCs.
+
+	  To compile this driver as a module, choose M here: the module will
+	  be called rcar_taurus_ether.
