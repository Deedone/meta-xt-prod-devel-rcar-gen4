From 81e68be2c5edec4ed8399f6247ce9c49ba3b5537 Mon Sep 17 00:00:00 2001
From: Phong Hoang <phong.hoang.wz@renesas.com>
Date: Sat, 7 Aug 2021 17:01:29 +0700
Subject: [PATCH 46/70] arm64: dts: renesas: Add r8a779m1 Salvator-XS cr7_rproc

This adds support for H3e Salvator-XS board.

Signed-off-by: Phong Hoang <phong.hoang.wz@renesas.com>
---
 arch/arm64/boot/dts/renesas/Makefile          |  1 +
 .../r8a779m1-salvator-xs_cr7_rproc.dts        | 22 +++++++++++++++++++
 2 files changed, 23 insertions(+)
 create mode 100644 arch/arm64/boot/dts/renesas/r8a779m1-salvator-xs_cr7_rproc.dts

diff --git a/arch/arm64/boot/dts/renesas/Makefile b/arch/arm64/boot/dts/renesas/Makefile
index e002ae79948c..de2ddfbad129 100644
--- a/arch/arm64/boot/dts/renesas/Makefile
+++ b/arch/arm64/boot/dts/renesas/Makefile
@@ -35,6 +35,7 @@ dtb-$(CONFIG_ARCH_R8A77951) += r8a77951-ulcb-kf.dtb
 
 dtb-$(CONFIG_ARCH_R8A77951) += r8a779m1-salvator-x.dtb
 dtb-$(CONFIG_ARCH_R8A77951) += r8a779m1-salvator-xs.dtb
+dtb-$(CONFIG_ARCH_R8A77951) += r8a779m1-salvator-xs_cr7_rproc.dtb
 dtb-$(CONFIG_ARCH_R8A77951) += r8a779m1-ulcb.dtb
 dtb-$(CONFIG_ARCH_R8A77951) += r8a779m1-ulcb-kf.dtb
 
diff --git a/arch/arm64/boot/dts/renesas/r8a779m1-salvator-xs_cr7_rproc.dts b/arch/arm64/boot/dts/renesas/r8a779m1-salvator-xs_cr7_rproc.dts
new file mode 100644
index 000000000000..344c891f8b22
--- /dev/null
+++ b/arch/arm64/boot/dts/renesas/r8a779m1-salvator-xs_cr7_rproc.dts
@@ -0,0 +1,22 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Device Tree Source for the Salvator-X 2nd version board with R-Car H3e
+ *
+ * Copyright (C) 2021 Renesas Electronics Corp.
+ */
+
+/dts-v1/;
+#include "r8a779m1-salvator-xs.dts"
+#include "salvator-xs_cr7_rproc.dtsi"
+
+/delete-node/ &hdmi1;
+/delete-node/ &hdmi1_con;
+
+&rcar_sound {
+	ports {
+		/delete-node/ port@2;
+	};
+};
+
+/delete-node/ &fcpvd2;
+/delete-node/ &vspd2;
