From 88bd2020f99a2898a39c18948d657c3223933775 Mon Sep 17 00:00:00 2001
From: Phil Edworthy <phil.edworthy@renesas.com>
Date: Thu, 21 Jan 2021 10:18:48 +0000
Subject: [PATCH 19/70] arm64: dts: Change E3 RVGC layer size and position

The RVGC virtual display is set to 800x600, located in the centre of a 1920x720 display.
This is chosen for a good demo using the 2D-WOW CR7 application.
---
 arch/arm64/boot/dts/renesas/ebisu-4d_cr7_rproc.dtsi | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/arch/arm64/boot/dts/renesas/ebisu-4d_cr7_rproc.dtsi b/arch/arm64/boot/dts/renesas/ebisu-4d_cr7_rproc.dtsi
index fb4fc135e546..96132ed2a122 100644
--- a/arch/arm64/boot/dts/renesas/ebisu-4d_cr7_rproc.dtsi
+++ b/arch/arm64/boot/dts/renesas/ebisu-4d_cr7_rproc.dtsi
@@ -51,12 +51,12 @@ display-0 {
 				layers{
 					/* layer-map correspond to vpsd rpf (lower values are higher "z") */
 					primary{
+						/* Position the layer in the centre of a 1920x720 display */
 						layer-map=<0x4>;
-						size-w=<640>;
-						size-h=<480>;
-						pos-x=<100>;
-						pos-y=<100>;
-						/* override the default 0,0 position */
+						size-w=<800>;
+						size-h=<600>;
+						pos-x=<560>;	// (1920 - 800)/2
+						pos-y=<60>;	// (720 - 600)/2
 						pos-override;
 						/* don't actually output the plane to vspd */
 						// no-scan;
-- 
