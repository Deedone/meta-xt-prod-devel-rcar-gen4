From 503b48cc4659914f279faf9d2ea9aa0dbf83cf2a Mon Sep 17 00:00:00 2001
From: Linh Phung <linh.phung.jy@renesas.com>
Date: Wed, 6 Apr 2022 13:17:27 +0700
Subject: [PATCH 69/70] clk: renesas: r8a7795: Disable CAN-FD core clock

This patch is necessary for Para-CAN support to prevent HW overwrite.

Signed-off-by: Linh Phung <linh.phung.jy@renesas.com>
---
 drivers/clk/renesas/r8a7795-cpg-mssr.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/drivers/clk/renesas/r8a7795-cpg-mssr.c b/drivers/clk/renesas/r8a7795-cpg-mssr.c
index f8f90e218b0b..05394acda785 100644
--- a/drivers/clk/renesas/r8a7795-cpg-mssr.c
+++ b/drivers/clk/renesas/r8a7795-cpg-mssr.c
@@ -108,7 +108,6 @@ static struct cpg_core_clk r8a7795_core_clks[] __initdata = {
 	DEF_FIXED("cp",         R8A7795_CLK_CP,    CLK_EXTAL,      2, 1),
 	DEF_FIXED("cpex",       R8A7795_CLK_CPEX,  CLK_EXTAL,      2, 1),
 
-	DEF_DIV6P1("canfd",     R8A7795_CLK_CANFD, CLK_PLL1_DIV4, 0x244),
 	DEF_DIV6P1("csi0",      R8A7795_CLK_CSI0,  CLK_PLL1_DIV4, 0x00c),
 	DEF_DIV6P1("mso",       R8A7795_CLK_MSO,   CLK_PLL1_DIV4, 0x014),
 	DEF_DIV6P1("hdmi",      R8A7795_CLK_HDMI,  CLK_PLL1_DIV4, 0x250),
-- 
