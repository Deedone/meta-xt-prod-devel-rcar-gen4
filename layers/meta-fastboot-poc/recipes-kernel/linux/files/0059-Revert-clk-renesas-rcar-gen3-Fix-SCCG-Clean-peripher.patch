From 1d2063a14322c48380fa6f0129c48d2006d7b563 Mon Sep 17 00:00:00 2001
From: LUU HOAI <hoai.luu.ub@renesas.com>
Date: Mon, 21 Feb 2022 16:56:07 +0900
Subject: [PATCH 59/70] Revert "clk: renesas: rcar-gen3: Fix SCCG/Clean
 peripheral clocks definition"

The definition of SCCG/Clean peripheral clocks is not corrected,
so this patch should be removed.

This reverts commit e47c3bbf9fdff8663c532cbdfb37fe2679c12269.

Signed-off-by: LUU HOAI <hoai.luu.ub@renesas.com>
---
 drivers/clk/renesas/rcar-gen3-cpg.h | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/drivers/clk/renesas/rcar-gen3-cpg.h b/drivers/clk/renesas/rcar-gen3-cpg.h
index 98de9ae2274c..687fde1f43f2 100644
--- a/drivers/clk/renesas/rcar-gen3-cpg.h
+++ b/drivers/clk/renesas/rcar-gen3-cpg.h
@@ -40,10 +40,10 @@ enum rcar_gen3_clk_types {
 		 (_parent0) << 16 | (_parent1),		\
 		 .div = (_div0) << 16 | (_div1), .offset = _md)
 
-#define DEF_GEN3_PE(_name, _id, _parent_clean, _div_clean, _parent_sscg, \
-		    _div_sscg) \
-	DEF_GEN3_MDSEL(_name, _id, 12, _parent_clean, _div_clean,	\
-		       _parent_sscg, _div_sscg)
+#define DEF_GEN3_PE(_name, _id, _parent_sscg, _div_sscg, _parent_clean, \
+		    _div_clean) \
+	DEF_GEN3_MDSEL(_name, _id, 12, _parent_sscg, _div_sscg,	\
+		       _parent_clean, _div_clean)
 
 #define DEF_GEN3_OSC(_name, _id, _parent, _div)		\
 	DEF_BASE(_name, _id, CLK_TYPE_GEN3_OSC, _parent, .div = _div)
